---
const faqs = [
  {
    q: "How does your pricing work?",
    a: "Flat-rate, quoted upfront. After a quick on-site diagnosis we give you a firm price for the whole job. You approve it before any work begins — no hourly surprises.",
  },
  {
    q: "Are you licensed and insured?",
    a: "Fully licensed, bonded, and insured. We'll happily show proof on request.",
  },
  {
    q: "Do you charge a call-out fee?",
    a: "A small diagnostic fee applies and is credited toward the job if you proceed. If we miss your scheduled window, we waive it entirely.",
  },
  {
    q: "What areas do you cover?",
    a: "All of the communities listed above. If you're just outside, call us — we often travel for the right job.",
  },
];
---

<section class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center">
      <p class="text-sm/6 font-semibold uppercase tracking-widest text-gold-500">Good to know</p>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
        Questions we hear a lot.
      </h2>
    </div>
    <dl class="mt-12 space-y-4">
      {faqs.map((faq) => (
        <details class="group rounded-xl border border-gray-200 bg-white open:shadow-sm transition-shadow">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-base font-semibold text-gray-900 list-none">
            {faq.q}
            <svg class="h-5 w-5 flex-shrink-0 text-gray-400 transition-transform group-open:rotate-45" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
            </svg>
          </summary>
          <div class="border-t border-gray-100 px-6 py-5">
            <p class="text-sm leading-relaxed text-gray-500">{faq.a}</p>
          </div>
        </details>
      ))}
    </dl>
  </div>
</section>
