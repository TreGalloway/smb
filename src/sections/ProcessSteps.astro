---
const steps = [
  {
    number: "1",
    title: "Call or book",
    text: "Tell us what's going on. We'll give you a real arrival window — not 'sometime today.'",
  },
  {
    number: "2",
    title: "Upfront quote",
    text: "Our technician diagnoses on-site and quotes a flat price before lifting a tool.",
  },
  {
    number: "3",
    title: "We fix it",
    text: "Most jobs done the same visit, with common parts stocked on the truck.",
  },
  {
    number: "4",
    title: "Guaranteed",
    text: "We clean up, walk you through the work, and back it in writing.",
  },
];
---

<section class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center">
      <p class="text-sm/6 font-semibold uppercase tracking-widest text-gold-500">How it works</p>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
        Four steps, zero headaches.
      </h2>
    </div>
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step) => (
        <div class="relative rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-royal-800 text-lg font-bold text-white">
            {step.number}
          </span>
          <h3 class="mt-4 text-lg font-bold text-gray-900">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
