---
import type { Review } from "../types";

export interface Props {
  reviews: Review[];
}

const { reviews } = Astro.props;
---

<section class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center">
      <p class="text-sm/6 font-semibold uppercase tracking-widest text-gold-500">Hear from our customers</p>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
        Real people, real results.
      </h2>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {reviews.map((review) => (
        <div class="flex flex-col rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-200">
          <div class="flex gap-1 text-gold-500">
            {[...Array(5)].map((_, i) => (
              <svg key={i} class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="mt-4 flex-1 text-base leading-relaxed text-gray-600 italic">
            &ldquo;{review.text}&rdquo;
          </p>
          <p class="mt-6 text-sm font-semibold text-gray-900">— {review.name}</p>
        </div>
      ))}
    </div>
  </div>
</section>
