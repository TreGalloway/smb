---
import type { Service } from "../types";
import { urlFor } from "../lib/sanity";

export interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<section id="services" class="relative overflow-hidden bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-sm/6 font-semibold uppercase tracking-widest text-gold-500">What we do</h2>
    <p class="mt-3 text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
      Every job, big or small — handled.
    </p>

    <div class="mt-16 lg:grid lg:grid-cols-2 lg:gap-16 xl:gap-24">
      <div class="divide-y divide-gray-200">
        {
          services.map((service, index) => (
            <div class="group relative flex items-start gap-6 py-6 transition-colors duration-300">
              <span
                class="flex-shrink-0 text-4xl font-extrabold tracking-tight text-gray-300 transition-colors duration-300 group-hover:text-gold-500"
              >
                {String(service.sequenceNumber).padStart(2, "0")}
              </span>
              <div class="min-w-0 flex-1">
                <h3 class="text-xl font-bold text-gray-900 transition-colors duration-300 group-hover:text-royal-800">
                  {service.title}
                </h3>
                {service.description && (
                  <p class="mt-2 text-base text-gray-500 leading-relaxed">{service.description}</p>
                )}
                {service.bulletPoints && service.bulletPoints.length > 0 && (
                  <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-1">
                    {service.bulletPoints.filter(Boolean).map((point) => (
                      <li class="flex items-center gap-1.5 text-sm text-gray-400">
                        <svg class="h-3.5 w-3.5 flex-shrink-0 text-gold-500" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                        </svg>
                        {point}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
              {service.mainImage && (
                <div class="hidden lg:block absolute right-0 top-1/2 -translate-y-1/2 w-72 opacity-0 pointer-events-none transition-all duration-500 group-hover:opacity-100 group-hover:translate-x-0 translate-x-4">
                  <div class="aspect-[4/3] overflow-hidden rounded-lg shadow-xl">
                    <img
                      src={urlFor(service.mainImage).width(600).height(450).fit("crop").url()}
                      alt={service.mainImage.alt ?? service.title}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>
      <div class="hidden lg:block">
        <div class="sticky top-32 aspect-[4/3] overflow-hidden rounded-2xl bg-gray-100 shadow-lg">
          {
            services.map((service, index) => (
              <div class="absolute inset-0 transition-opacity duration-500 opacity-0 preview-{index}">
                {service.mainImage && (
                  <img
                    src={urlFor(service.mainImage).width(800).height(600).fit("crop").url()}
                    alt={service.mainImage.alt ?? service.title}
                    class="h-full w-full object-cover"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const groups = document.querySelectorAll('[id^="services"] .group');
  const previews = document.querySelectorAll('[class*="preview-"]');
  let activeIndex = -1;

  groups.forEach((group, index) => {
    group.addEventListener("mouseenter", () => {
      if (activeIndex !== -1) {
        previews[activeIndex]?.classList.remove("opacity-100");
      }
      previews[index]?.classList.add("opacity-100");
      activeIndex = index;
    });
  });

  const container = document.querySelector('[id^="services"]');
  if (container) {
    container.addEventListener("mouseleave", () => {
      if (activeIndex !== -1) {
        previews[activeIndex]?.classList.remove("opacity-100");
        activeIndex = -1;
      }
    });
  }
</script>
