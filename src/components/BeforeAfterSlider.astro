---
import type { BeforeAfter } from "../types";
import { urlFor } from "../lib/sanity";

export interface Props {
  item: BeforeAfter;
}

const { item } = Astro.props;

const beforeUrl = item.beforeImage
  ? urlFor(item.beforeImage).width(900).height(600).fit("crop").url()
  : "";
const afterUrl = item.afterImage
  ? urlFor(item.afterImage).width(900).height(600).fit("crop").url()
  : "";
---

<figure class="group relative select-none overflow-hidden rounded-2xl bg-gray-200 shadow-lg" data-slider>
  <div class="aspect-[3/2] w-full">
    <img
      class="absolute inset-0 h-full w-full object-cover"
      src={afterUrl}
      alt={item.afterImage?.alt ?? "After"}
      loading="lazy"
    />
    <div
      class="before-clip absolute inset-0 h-full w-full"
      style="clip-path: inset(0 50% 0 0)"
    >
      <img
        class="absolute inset-0 h-full w-full object-cover"
        src={beforeUrl}
        alt={item.beforeImage?.alt ?? "Before"}
        loading="lazy"
      />
    </div>
    <div
      class="slider-handle absolute top-0 bottom-0 z-10"
      style="left: calc(50% - 24px)"
    >
      <div class="relative flex h-full items-center">
        <div class="h-full w-0.5 bg-gold-500 shadow-lg" />
        <button
          class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex h-12 w-12 cursor-ew-resize items-center justify-center rounded-full border-2 border-gold-500 bg-white shadow-xl transition-transform active:scale-110"
          aria-label="Drag to compare before and after"
        >
          <svg class="h-5 w-5 text-gold-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  <figcaption class="flex flex-wrap items-center justify-between gap-2 bg-white px-6 py-4">
    <span class="flex items-center gap-4 text-sm">
      <span class="flex items-center gap-1.5">
        <span class="h-2.5 w-2.5 rounded-full bg-gold-500" />
        <span class="font-medium text-gray-900">Before</span>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="h-2.5 w-2.5 rounded-full bg-royal-800" />
        <span class="font-medium text-gray-900">After</span>
      </span>
    </span>
    <span class="text-sm font-medium text-gray-700">{item.title}</span>
  </figcaption>
  {item.description && (
    <div class="border-t border-gray-100 bg-white px-6 py-3">
      <p class="text-sm text-gray-500">{item.description}</p>
    </div>
  )}
</figure>
