---
import type { SanityImage } from "../types";
import { urlFor } from "../lib/sanity";

export interface Props {
  images: SanityImage[];
  alt?: string;
}

const { images, alt = "Gallery image" } = Astro.props;
---

<div class="group relative overflow-hidden rounded-2xl bg-gray-100">
  <div class="gallery-scroll flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2">
    {images.map((img, i) => {
      const src = urlFor(img).width(800).height(600).fit("crop").url();
      return (
        <div class="flex-shrink-0 w-[85%] md:w-[65%] snap-start overflow-hidden rounded-xl">
          <img
            src={src}
            alt={img.alt ?? alt}
            class="h-full w-full object-cover aspect-[4/3]"
            loading={i === 0 ? "eager" : "lazy"}
          />
        </div>
      );
    })}
  </div>

  <button
    class="gallery-prev absolute left-3 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/80 shadow-md opacity-0 transition-opacity duration-300 hover:bg-white group-hover:opacity-100"
    aria-label="Previous image"
  >
    <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button
    class="gallery-next absolute right-3 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/80 shadow-md opacity-0 transition-opacity duration-300 hover:bg-white group-hover:opacity-100"
    aria-label="Next image"
  >
    <svg class="h-5 w-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll(".gallery-scroll").forEach((scrollEl) => {
    const container = scrollEl.closest(".group") as HTMLElement;
    const prevBtn = container?.querySelector<HTMLButtonElement>(".gallery-prev");
    const nextBtn = container?.querySelector<HTMLButtonElement>(".gallery-next");
    if (!prevBtn || !nextBtn) return;

    function scrollStep(dir: number) {
      const w = scrollEl.clientWidth;
      scrollEl.scrollBy({ left: w * 0.85 * dir, behavior: "smooth" });
    }

    prevBtn.addEventListener("click", () => scrollStep(-1));
    nextBtn.addEventListener("click", () => scrollStep(1));
  });
</script>
