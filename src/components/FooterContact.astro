---
import type { CompanySettings } from "../types";

export interface Props {
  companySettings: CompanySettings | null;
}

const { companySettings } = Astro.props;

const FIELDS = [
  "Emergency plumbing",
  "Water heater",
  "Drain / sewer",
  "Heating / HVAC",
  "Repair / fixture",
  "Repipe / remodel",
  "Something else",
] as const;
---

<section class="relative bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 xl:gap-24">
      <div>
        <h2 class="text-sm/6 font-semibold uppercase tracking-widest text-gold-500">Free estimate</h2>
        <p class="mt-3 text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
          Get a fast, no-obligation quote.
        </p>
        <p class="mt-4 max-w-xl text-lg text-gray-500">
          Tell us what you need and we'll call you right back — usually within the hour during business hours.
        </p>
        {companySettings?.phone && (
          <p class="mt-6 text-sm text-gray-400">
            Prefer to talk now?{" "}
            <a href={`tel:${companySettings.phone.replace(/\s/g, "")}`} class="font-semibold text-royal-800 hover:text-royal-700 underline">
              {companySettings.phone}
            </a>
            <span class="ml-2">Mon–Sat 7am–8pm</span>
          </p>
        )}
        {companySettings?.address && (
          <div class="mt-8 border-t border-gray-200 pt-8">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900">Visit us</h3>
            <p class="mt-2 text-sm text-gray-500">{companySettings.address}</p>
          </div>
        )}
      </div>

      <div class="mt-12 lg:mt-0">
        <form
          action="/api/contact"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label for="name" class="sr-only">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Name"
              autocomplete="name"
              class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-4 text-base text-gray-900 placeholder-gray-400 focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/20 transition-colors"
            />
          </div>
          <div>
            <label for="service" class="sr-only">What do you need?</label>
            <select
              id="service"
              name="service"
              required
              class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-4 text-base text-gray-900 focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/20 transition-colors"
            >
              <option value="" disabled selected>What do you need?</option>
              {FIELDS.map((field) => (
                <option value={field.toLowerCase().replace(/[\/\s]+/g, "-")}>{field}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="message" class="sr-only">Tell us a bit more</label>
            <textarea
              id="message"
              name="message"
              rows={3}
              placeholder="Tell us a bit more (optional)"
              class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-4 text-base text-gray-900 placeholder-gray-400 focus:border-gold-500 focus:outline-none focus:ring-2 focus:ring-gold-500/20 transition-colors resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-royal-800 px-6 py-4 text-base font-semibold text-white shadow-sm hover:bg-royal-700 focus:outline-none focus:ring-2 focus:ring-royal-800/50 transition-colors"
          >
            Request my free quote
          </button>
        </form>
      </div>
    </div>

    <div class="mt-20 border-t border-gray-200 pt-10">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
        <p class="text-sm text-gray-400">
          &copy; {new Date().getFullYear()} {companySettings?.businessName ?? "SMB"}.
          {companySettings?.licenseNumbers?.length ? companySettings.licenseNumbers.join(" · ") : ""}
        </p>
        <div class="flex gap-4 text-sm text-gray-400">
          {companySettings?.email && (
            <a href={`mailto:${companySettings.email}`} class="hover:text-royal-700 transition-colors">
              {companySettings.email}
            </a>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="fixed bottom-0 left-0 right-0 z-40 lg:hidden">
    <div class="flex flex-col gap-2 bg-royal-800 py-3 pb-[env(safe-area-inset-bottom)]">
      {companySettings?.phone && (
        <a
          href={`tel:${companySettings.phone.replace(/\s/g, "")}`}
          class="flex w-full items-center justify-center gap-2 px-4 py-3 text-sm font-bold text-white transition-colors hover:bg-white/10"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          Call Now
        </a>
      )}
      <a
        href="#contact"
        class="flex w-full items-center justify-center gap-2 bg-gold-500 px-4 py-3 text-sm font-bold text-white transition-colors hover:bg-gold-600"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
        </svg>
        Request Quote
      </a>
    </div>
  </div>
  <div id="sticky-bar-observer" class="absolute -top-32 left-0 h-1 w-full"></div>
</section>

<style is:global>
  body {
    padding-bottom: 68px;
  }

  @media (min-width: 1024px) {
    body {
      padding-bottom: 0;
    }
  }
</style>

<script>
  const contactSection = document.getElementById("contact");
  const stickyBar = document.querySelector<HTMLElement>('[class*="fixed bottom-0"]');
  if (contactSection && stickyBar) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        stickyBar.style.display = entry.isIntersecting ? "none" : "flex";
      },
      { threshold: 0 },
    );
    observer.observe(contactSection);
  }
</script>
