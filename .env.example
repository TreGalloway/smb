# Sanity Configuration
# 1. Create a Sanity project at https://sanity.io
# 2. Copy your project ID and dataset name
# 3. Create an API token with read permissions
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production
SANITY_TOKEN=your-api-token

# Set this to your deployed site URL (used for CORS)
SITE_URL=http://localhost:4321
